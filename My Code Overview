/* so here i made an example of how to fix a join command if it fails*/
--the opposite of right join 
SELECT
c.first_name,
c.company,
b.Credit_Limit
From customers100 As C
left join BankChurners As B 
ON TRY_CAST(c.First_Name AS float)
= TRY_CAST(b.Credit_Limit As float);


--selects everything from the right table and matches from the left table 
select 
c.First_Name,
c.Country,
b.Gender
From customers100 As C
Right join BankChurners As B 
ON c.First_Name 
=
b.Gender

--selects everything from both tables it doesnt matter if there is a match or not
select
c.First_Name,
c.Email,
b.Income_Category
From customers100 As C 
FULL JOIN BankChurners As B 
ON C.First_Name 
=
b.Income_Category


